---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import shamanicHeart from '../assets/images/bigstock-shamanic-heart-44039758.jpg';
import profilovka from '../assets/images/saman-na-beltine.jpg';

// Get all blog posts and sort them by date
const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf();
});

// Show up to 5 posts on the frontpage
const posts = sortedPosts.slice(0, 5).map(post => ({
  ...post,
  url: `/posts/${post.id}`,
  frontmatter: post.data
}));
---

<BaseLayout
  title="Jan Čejka"
  description={`Osobní blog o šamanismu, léčení a práci s energií. Jan Čejka se věnuje léčitelství již ${new Date().getFullYear() - 1987} let a propojuje duchy přírodního světa s moderním myšlením.`}
  author="Jan Čejka"
>
  <div class="max-w-4xl mx-auto px-4 md:px-6">
    <section class="relative text-center py-[8vh] overflow-hidden" transition:animate="fade">

      <h1 class="text-7xl mb-6 font-bold relative z-10 font-handwrite leading-tight">
        <span class="block md:inline">šaman</span>
        <span class="hidden md:inline mx-2 opacity-40">·</span>
        <span class="block md:inline">léčitel</span>
        <span class="hidden md:inline mx-2 opacity-40">·</span>
        <span class="block md:inline">průvodce</span>
      </h1>

      <!-- Šamanské srdce jako dekorativní pozadí -->
      <div class="hero-heart absolute pointer-events-none select-none" aria-hidden="true">
        <Image
          src={shamanicHeart}
          alt=""
          class="w-[260px] h-[260px] md:w-[560px] md:h-[560px] object-contain opacity-[0.12] [mix-blend-mode:multiply] dark:opacity-[0.18] dark:invert dark:[mix-blend-mode:screen]"
          widths={[420, 560]}
          sizes="(max-width: 768px) 420px, 560px"
          quality={75}
          loading="eager"
        />
      </div>
      <p class="text-2xl text-muted-foreground max-w-3xl mx-auto mb-14 relative z-10">
        Průvodce světem šamanismu, energetického léčení a komunikace s přírodou. Věnuji se léčitelství již {new Date().getFullYear() - 1987} let a propojuji duchy přírodního světa s moderním myšlením.
      </p>
      <div class="flex flex-wrap gap-4 justify-center relative z-10">
        <a href="/journal" class="btn-primary btn-lg tracking-wide no-underline hover:no-underline transform transition-all duration-300 hover:scale-105 hover:shadow-[0_3.5rem_5rem_rgba(21,21,21,0.3)] shadow-[0_3rem_4rem_rgba(21,21,21,0.25)]">
          Číst zápisník
        </a>
        <a href="/about" class="btn-secondary btn-lg tracking-wide no-underline hover:no-underline">
          O mně
        </a>
      </div>
    </section>

    <section class="mx-auto" transition:animate="fade">
      <PostList posts={posts} showImages={false} showExcerpt={false} showSeparators={true} showTags={false}/>

      <div class="text-center mt-24">
        <a href="/journal" class="text-lg font-medium text-black dark:text-white py-2 px-4 rounded-md inline-block focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 hover:underline">
          Všechny příspěvky <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    <!-- Autorská karta -->
    <section class="mt-20 mb-4" transition:animate="fade">
      <a href="/about" class="group flex flex-col sm:flex-row items-center sm:items-start gap-6 p-7 rounded-2xl border border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-900/40 hover:border-ritual/30 dark:hover:border-ritual/20 transition-all duration-300 no-underline hover:no-underline hover:shadow-md">
        <div class="flex-shrink-0">
          <div class="w-20 h-20 rounded-full overflow-hidden ring-2 ring-ritual/20 shadow-md group-hover:ring-ritual/40 transition-all duration-300">
          <Image
              src={profilovka}
              alt="Jan Čejka"
              class="w-full h-full object-cover object-center"
              width={80}
              height={80}
              quality={85}
              loading="lazy"
            />
          </div>
        </div>
        <div class="text-center sm:text-left">
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-ritual mb-1">Autor</p>
          <p class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-1 group-hover:text-ritual transition-colors duration-300">Jan Čejka</p>
          <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">
            Léčitel a šaman věnující se své práci od 17 let. Propojuje pradávnou moudrost s moderním myšlením.
          </p>
        </div>
        <div class="sm:ml-auto flex-shrink-0 self-center">
          <span class="text-ritual text-xl group-hover:translate-x-1 inline-block transition-transform duration-300">→</span>
        </div>
      </a>
    </section>
  </div>

<style>
  .hero-heart {
    top: 35%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 0;
  }

  @media (min-width: 768px) {
    .hero-heart {
      top: 50%;
    }
  }
</style>
</BaseLayout>
