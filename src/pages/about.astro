---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="O mně"
  description="Jan Čejka — léčitel, šaman a průvodce světem energie. Věnuji se léčitelství od svých 17 let."
  author="Jan Čejka"
  image="/images/portret-2025-07-16-125057.jpg"
>
  <!-- ═══════════════════════════════════════════
       HERO — portrét + úvod
  ═══════════════════════════════════════════ -->
  <section class="about-hero relative overflow-hidden py-16 md:py-24">


    <div class="relative max-w-5xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_260px] gap-12 md:gap-16 items-center">

        <!-- Text -->
        <div transition:animate="fade">
          <p class="text-ritual font-mono text-xs uppercase tracking-[0.25em] mb-5">Léčitel · Šaman · Průvodce</p>
          <h1 class="about-title leading-none mb-6" style="margin-top:0;">Jan<br>Čejka</h1>
          <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed max-w-lg mb-10">
            Věnuji se léčitelství od svých 17 let. Narodil jsem se v roce 1971 a celý
            svůj život propojuji duchy přírodního světa s moderním myšlením — hledám
            mosty mezi pradávnou moudrostí a každodenním životem.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/journal" class="btn-primary no-underline hover:no-underline">Číst zápisník</a>
            <a href="mailto:posta@jancejka.cz" class="btn-secondary no-underline hover:no-underline">Napsat mi</a>
          </div>
        </div>

        <!-- Kruhový portrét -->
        <div class="overflow-hidden md:overflow-visible flex justify-center md:justify-end" transition:animate="fade">
          <!-- Wrapper = velikost portrétu; buben + prsteny přetékají přes overflow:visible -->
          <div class="portrait-wrapper relative w-52 h-52 md:w-64 md:h-64" style="overflow:visible">

            <!-- Buben: centrován přes translate, přetéká mimo wrapper -->
            <img
              src="/images/bigstock-shaman-drum-44041465.jpg"
              alt=""
              aria-hidden="true"
              class="drum-bg absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 object-contain pointer-events-none select-none opacity-[0.05] dark:opacity-[0.15] dark:invert dark:[mix-blend-mode:screen]"
              style="z-index:0"
            >

            <!-- Prsteny: vnější div centruje (translate), vnitřní div jen rotuje -->
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none w-[240px] h-[240px] md:w-[296px] md:h-[296px]" style="z-index:1">
              <div class="ring-outer w-full h-full rounded-full border border-ritual/25"></div>
            </div>
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none w-[272px] h-[272px] md:w-[328px] md:h-[328px]" style="z-index:1">
              <div class="ring-inner w-full h-full rounded-full border border-copper/15"></div>
            </div>
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none w-[312px] h-[312px] md:w-[368px] md:h-[368px]" style="z-index:1">
              <div class="ring-dot w-full h-full rounded-full border border-dashed border-sage/20"></div>
            </div>

            <!-- Portrét: vyplňuje wrapper -->
            <div class="w-full h-full rounded-full overflow-hidden shadow-2xl shadow-ritual/15 ring-2 ring-ritual/20" style="position:relative; z-index:2">
              <img
                src="/images/portret-2025-07-16-125057.jpg"
                alt="Jan Čejka — fotografie"
                class="w-full h-full object-cover object-center"
                loading="eager"
              >
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       DRAMATICKÝ BANNER — šaman s pochodní
  ═══════════════════════════════════════════ -->
  <div class="max-w-5xl mx-auto px-4 my-10 md:my-14" transition:animate="fade">
    <div class="relative h-56 md:h-72 rounded-2xl overflow-hidden shadow-2xl shadow-black/30">
      <img
        src="/images/bigstock-Portrait-of-a-shaman-with-a-dr-58717124.jpg"
        alt="Šaman s pochodní a peřím"
        class="w-full h-full object-cover"
        style="object-position: center 15%;"
      >
      <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/50 to-transparent flex items-center">
        <blockquote class="px-8 md:px-14 max-w-sm md:max-w-md">
          <p class="text-xl md:text-2xl text-white font-medium leading-snug italic">
            „Propojuji pradávnou moudrost<br>s moderním světem."
          </p>
        </blockquote>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       OBSAH — aktivity, publikace, kontakt
  ═══════════════════════════════════════════ -->
  <div class="max-w-3xl mx-auto px-4 pb-20" transition:animate="fade">

    <div class="prose prose-lg dark:prose-invert max-w-none">
      <h2>Čím se zabývám</h2>
      <ul>
        <li>Šamanské praktiky, tradice a cesty</li>
        <li>Energetické léčení a práce s tělem i duší</li>
        <li>Komunikace s duchy přírody, elementy, rostlinami a zvířaty</li>
        <li>Harmonizace a čištění prostor</li>
        <li>Síť světelných sloupů — energetická síť vyzařující uzdravení a lásku</li>
      </ul>
    </div>

    <!-- Publikace -->
    <div class="my-10">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-mystic dark:text-mystic mb-8">Publikace</h2>
      <div class="flex flex-col sm:flex-row gap-8 items-start sm:items-center p-6 bg-gray-50 dark:bg-gray-900/50 rounded-2xl border border-gray-100 dark:border-gray-800">
        <div class="flex-shrink-0">
          <img
            src="/images/mvu-ctverec.jpg"
            alt="Magie Vědomého Uzdravení — obálka"
            class="w-36 h-36 object-cover rounded-xl shadow-lg"
          >
        </div>
        <div>
          <p class="font-mono text-xs text-gray-400 dark:text-gray-500 uppercase tracking-widest mb-1">Jan Čejka © 2014</p>
          <h3 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-3 leading-tight" style="margin-top:0;">Magie Vědomého Uzdravení</h3>
          <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-0">
            Praktický průvodce vědomým uzdravením. Metody, jak se uzdravit za 21 dní bez léků
            a lékaře — propojení šamanské moudrosti s moderním přístupem ke zdraví.
          </p>
        </div>
      </div>
    </div>

    <div class="prose prose-lg dark:prose-invert max-w-none">
      <h2>Zápisník</h2>
      <p>
        V tomto zápisníku sdílím zkušenosti, postřehy a příběhy z cesty léčitele.
        Pokud tě zajímá svět šamanismu a práce s energií, nahlédni do <a href="/journal">zápisníku</a>.
      </p>

      <h2>Kontakt</h2>
      <ul>
        <li>
          <strong>E-mail:</strong>{' '}
          <a href="mailto:posta@jancejka.cz">posta@jancejka.cz</a>
        </li>
        <li>
          <strong>Telefon</strong> (ideálně SMS, volání často nezvedám):{' '}
          <a href="tel:+420799797393">+420 799 797 393</a>
        </li>
        <li>
          <strong>SimpleX Chat:</strong>{' '}
          <a href="https://smp10.simplex.im/a#KbPpST2bUHXKoEEwUOeJ1UT1OMglLEDevaFAa172cR4" rel="noopener noreferrer" target="_blank">pozvánka do chatu</a>
        </li>
        <li>
          <strong>Mastodon:</strong>{' '}
          <a href="https://mastodon.social/@Merguian" rel="me noopener noreferrer" target="_blank">@Merguian@mastodon.social</a>
        </li>
      </ul>
    </div>
  </div>
</BaseLayout>

<style>
  /* Velký titul na stránce O mně — překrývá base h1 styly */
  .about-title {
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-ritual);
    line-height: 0.95;
  }

  /* Buben — rozměry v CSS, ne Tailwind arbitrary (spolehlivější v TW v4) */
  .drum-bg {
    width: 400px;
    height: 400px;
    max-width: none;
  }

  @media (min-width: 768px) {
    .drum-bg {
      width: 600px;
      height: 600px;
      max-width: none;
    }
  }

  /* Prsteny — centering řeší flex wrapper, animace jen rotáčí */
  .ring-outer {
    animation: slowSpinFwd 28s linear infinite;
  }

  .ring-inner {
    animation: slowSpinRev 42s linear infinite;
  }

  .ring-dot {
    animation: slowSpinFwd 60s linear infinite;
  }

  @keyframes slowSpinFwd {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  @keyframes slowSpinRev {
    from { transform: rotate(0deg); }
    to   { transform: rotate(-360deg); }
  }
</style>
